# Copy to .env to override defaults. All vars are optional.
# Paths default to the sibling LeafDiseaseDetection-DL project.

# LEAFLENS_CLASSIFICATION_DIR=../LeafDiseaseDetection-DL/Classification Data
# LEAFLENS_SEGMENTATION_DIR=../LeafDiseaseDetection-DL/Image Segmentation Data
# LEAFLENS_ARTIFACTS_DIR=./artifacts

# Training
# LEAFLENS_BATCH_SIZE=16
# LEAFLENS_HEAD_EPOCHS=12
# LEAFLENS_FINETUNE_EPOCHS=8
# LEAFLENS_SEG_SAMPLE_RATIO=0.5
# LEAFLENS_SEED=42
